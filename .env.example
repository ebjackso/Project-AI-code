# Firebase Configuration
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# AI Provider Configuration
EXPO_PUBLIC_AI_PROVIDER=openai
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_key
# Alternatively for Grok:
# EXPO_PUBLIC_AI_PROVIDER=grok
# EXPO_PUBLIC_GROK_API_KEY=your_grok_key
# Or for Claude:
# EXPO_PUBLIC_AI_PROVIDER=claude
# EXPO_PUBLIC_CLAUDE_API_KEY=your_claude_key

# Firebase Cloud Functions URL (for server-side summarization)
EXPO_PUBLIC_CLOUD_FUNCTIONS_URL=https://your-region-your-project.cloudfunctions.net

# Feature Flags
EXPO_PUBLIC_ENABLE_ANONYMOUS_MODE=true
EXPO_PUBLIC_DEFAULT_RADIUS_KM=5
EXPO_PUBLIC_SUMMARY_REFRESH_INTERVAL_MS=120000
